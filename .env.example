# StructureBot — environment configuration
# Copy this file to .env.local and fill in your values; .env.local is loaded
# automatically at startup (and is gitignored).
#
# EVERYTHING here is OPTIONAL — config.py ships working defaults for all of it, and
# the test suite needs NO .env.local. NL translation is LOCAL-ONLY (Ollama); there
# is no API key to set.

# ── ChimeraX ───────────────────────────────────────────────────────────────────
# Full path to ChimeraX.exe (auto-detected from common install locations if unset).
# CHIMERAX_PATH=C:\Program Files\ChimeraX 1.11.1\bin\ChimeraX.exe

# REST server address / port / per-command timeout (seconds)
# CHIMERAX_HOST=127.0.0.1
# CHIMERAX_PORT=60001
# CHIMERAX_TIMEOUT=10

# ── Local LLM (Ollama) — the ONLY translation backend ──────────────────────────
# Ollama must be running and the model pulled:  ollama pull qwen3:8b
# Requires Ollama >= 0.30.0 (the Blackwell/sm_120 GPU floor).
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_TIMEOUT=120
# OLLAMA_NUM_CTX=16384
# OLLAMA_KEEP_ALIVE=30s

# ── App behaviour ──────────────────────────────────────────────────────────────
# Seconds before auto-executing high/medium-confidence commands (0 = always confirm)
# AUTO_PROCEED_DELAY=2
# Rolling conversation turns kept in memory (pairs of user+assistant)
# MAX_CONVERSATION_HISTORY=6
# Where to write session logs (.jsonl) and saved sessions (.cxs + .json)
# STRUCTUREBOT_LOG_DIR=./logs
# STRUCTUREBOT_SESSION_DIR=./sessions

# ── Sequence Editor / ProteinMPNN (optional) ───────────────────────────────────
# Clone ProteinMPNN or LigandMPNN and point to it for sequence redesign:
# PROTEINMPNN_DIR=C:/path/to/ProteinMPNN

# ── Stability / ddG backend ────────────────────────────────────────────────────
# auto (default) — PyRosetta if available, else DynaMut2 web API
# dynamut2 | empirical | pyrosetta | local
# ROSETTA_BACKEND=auto
# ROSETTA_LOCAL_PATH=/path/to/rosetta/source/bin   # only for ROSETTA_BACKEND=local
