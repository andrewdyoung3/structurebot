# StructureBot — environment configuration
# Copy this file to .env.local and fill in your values.
# .env.local is loaded automatically at startup.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional overrides (these match config.py defaults) ───────────────────────

# Full path to ChimeraX.exe
# CHIMERAX_PATH=C:\Users\andre\documents\ChimeraX 1.11.1\bin\ChimeraX.exe

# ChimeraX REST server address and port
# CHIMERAX_HOST=127.0.0.1
# CHIMERAX_PORT=60001

# Seconds each REST command is allowed before timing out
# CHIMERAX_TIMEOUT=10

# Anthropic model to use
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Rolling conversation turns kept in memory (pairs of user+assistant)
# MAX_CONVERSATION_HISTORY=6

# Seconds before auto-executing high/medium-confidence commands (0 = always confirm)
# AUTO_PROCEED_DELAY=2

# Where to write session logs (.jsonl) and saved sessions (.cxs + .json)
# STRUCTUREBOT_LOG_DIR=./logs
# STRUCTUREBOT_SESSION_DIR=./sessions

# ── Stability / ddG backend ───────────────────────────────────────────────────
#
# Default backend: DynaMut2 (free web API, no registration required).
# Only set ROSETTA_BACKEND if you want to override the default.
#
# Options:
#   auto       — PyRosetta if available, else DynaMut2 (default)
#   dynamut2   — DynaMut2 web API (biosig.lab.uq.edu.au/dynamut2)
#   empirical  — offline BLOSUM62 estimates (no network, r~0.4)
#   pyrosetta  — local PyRosetta (Python <= 3.13 + wheel required)
#   local      — local Rosetta binary (Linux/Mac, requires license)
#
# ROSETTA_BACKEND=auto

# ── PyRosetta (optional, future) ──────────────────────────────────────────────
# Uncomment and set true once PyRosetta is installed.
# Python 3.14 wheels not yet available; requires Python <= 3.13.
# See rosetta_bridge._run_pyrosetta() for setup instructions.
#
# PYROSETTA_AVAILABLE=false

# ── Local Rosetta binary (optional, future, Linux/Mac only) ───────────────────
# Set ROSETTA_BACKEND=local and point ROSETTA_LOCAL_PATH to the Rosetta bin/.
# Requires a free academic license from https://rosettacommons.org
# Expected accuracy: Pearson r ~0.8 vs experimental (CartesianDDG protocol).
#
# ROSETTA_LOCAL_PATH=/path/to/rosetta/source/bin
